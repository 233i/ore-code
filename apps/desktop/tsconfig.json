{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@seekforge/agent-core": ["../../packages/agent-core/src/index.ts"],
      "@seekforge/protocol": ["../../packages/protocol/src/index.ts"],
      "@seekforge/state": ["../../packages/state/src/index.ts"],
      "@seekforge/tools": ["../../packages/tools/src/index.ts"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src", "../../packages/*/src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
