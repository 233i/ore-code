  },
  "dependencies": {
    "@seekforge/protocol": "workspace:*",
    "smol-toml": "^1.6.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "typescript": "~5.8.3",
    "vitest": "^4.0.8"
  }
}
