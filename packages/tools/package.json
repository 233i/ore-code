{
  "name": "@seekforge/tools",
  "private": true,
  "version": "0.1.0",
  "description": "SeekForge tool schemas, approval policy, and tool helpers",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
