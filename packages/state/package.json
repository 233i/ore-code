{
  "name": "@ore-code/state",
  "private": true,
  "version": "0.1.0",
  "description": "Ore Code session, event, artifact, and persisted state helpers",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src --passWithNoTests",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@ore-code/protocol": "workspace:*"
  },
  "devDependencies": {
    "typescript": "~5.8.3",
    "vitest": "^4.0.8"
  }
}
