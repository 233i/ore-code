{
  "name": "@ore-code/harness",
  "private": true,
  "version": "0.1.0",
  "description": "Ore Code deterministic scenario replay and harness tests",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm --filter @ore-code/protocol build && pnpm --filter @ore-code/tools build && pnpm --filter @ore-code/agent-core build && vitest run src",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@ore-code/agent-core": "workspace:*",
    "@ore-code/protocol": "workspace:*",
    "@ore-code/state": "workspace:*",
    "@ore-code/tools": "workspace:*"
  },
  "devDependencies": {
    "typescript": "~5.8.3",
    "vitest": "^4.0.8"
  }
}
